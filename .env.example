# Frontend (Vite) - copiá esto a `.env.local` en la raiz del proyecto.
# Supabase necesita variables con prefijo `VITE_` para estar disponibles en el navegador.
# Google OAuth NO usa una variable Vite en este proyecto: se configura en Supabase Auth > Providers > Google.
# Si usás las funciones de Gmail/Drive/Calendar, además necesitás GOOGLE_CLIENT_ID y
# GOOGLE_CLIENT_SECRET como secrets del proyecto Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
