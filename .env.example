# Copy to .env.local (or .env) and fill real values.
# Frontend (Vite): only public / publishable values belong here.
# Never put SERVICE_ROLE, OPENROUTER, STRIPE_SECRET or GOOGLE_CLIENT_SECRET here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_AUTH_REDIRECT_ORIGIN=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=

# Stripe Checkout Payment Links or Checkout URLs (public)
VITE_STRIPE_CHECKOUT_TACTICAL=
VITE_STRIPE_CHECKOUT_PREMIUM=
VITE_STRIPE_CHECKOUT_MASTERMIND=
VITE_STRIPE_CHECKOUT_ENTERPRISE=
VITE_STRIPE_CHECKOUT_ALLIANCE=
